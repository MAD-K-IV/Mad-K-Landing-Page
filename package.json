{
  "name": "mad-k",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "dist-functions/index.js",
  "scripts": {
    "dev": "tsx server.ts",
    "build:frontend": "vite build",
    "build:server": "esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "build:functions": "esbuild src/functions/index.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist-functions/index.js",
    "build": "npm run build:frontend && npm run build:server && npm run build:functions",
    "start": "node dist/server.cjs",
    "clean": "rm -rf dist dist-functions server.js",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "firebase-admin": "^13.10.0",
    "firebase-functions": "^7.2.5",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-markdown": "^10.1.0",
    "three": "^0.185.1",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/three": "^0.185.1",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
